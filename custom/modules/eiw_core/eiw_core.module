<?php

use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\file\Entity\File;
use Drupal\Core\Link;
use Drupal\Core\Url;
use SearchApi\Item\ItemInterface;

/**
 * Implements hook_ENTITY_TYPE_presave().
 */
function eiw_core_node_presave($entity) {
  // Check if the entity is a node of type 'eiw_will'.
  if ($entity->bundle() === 'eiw_will') {
    // Set title to name/date values (single value fields).
    $last_name = $entity->get('field_last_name')->value != '' ? 
      trim($entity->get('field_last_name')->value) :
      'N/A';
    $first_name = !$entity->get('field_first_name')->isEmpty() ? 
      ', ' . trim($entity->get('field_first_name')->value) :
      ''
    ;
    $date = !$entity->get('field_date_of_probate')->isEmpty() ?
      ' [ ' . $entity->get('field_date_of_probate')->value . ' ]': 
      ' [ n.d. ]'
    ;
    
    $entity->setTitle($last_name . $first_name . $date);
    // Update document images PDF filename.
    if ($entity->hasField('field_document_images') && 
    !$entity->get('field_document_images')->isEmpty()) {
      $file = $entity->get('field_document_images')->entity;
      if ($file instanceof File) {
        // Set new filename
        $file->setFilename(strtolower(slugify($entity->getTitle())) . '.pdf');
        $file->save();
      }
    }
  }
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function eiw_core_form_node_eiw_will_form_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id) {
  $node = $form_state->getFormObject()->getEntity();
  // Set default date.
  if ($node->isNew()) {
    $default_date = '1500-01-01';

    if (isset($form['field_date_of_will']['widget'][0]['value'])) {
      $form['field_date_of_will']['widget'][0]['value']['#default_value'] = $default_date;
    }
    if (isset($form['field_date_of_probate']['widget'][0]['value'])) {
      $form['field_date_of_probate']['widget'][0]['value']['#default_value'] = $default_date;
    }
  }
}

function eiw_core_form_taxonomy_overview_terms_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id) {
  // Try to get the vocabulary from the route if not set in the form.
  $vocabulary_name = NULL;
  if (isset($form['#vocabulary'])) {
    $vocabulary_name = is_object($form['#vocabulary']) && method_exists($form['#vocabulary'], 'id') ? $form['#vocabulary']->id() : NULL;
  }
  else {
    // Get from route.
    $route_match = \Drupal::routeMatch();
    $route_vocabulary = $route_match->getParameter('taxonomy_vocabulary');
    if (is_object($route_vocabulary) && method_exists($route_vocabulary, 'id')) {
      $vocabulary_name = $route_vocabulary->id();
    }
    elseif (is_string($route_vocabulary)) {
      $vocabulary_name = $route_vocabulary;
    }
    else {
      \Drupal::logger('eiw_core')->notice('No vocabulary found on route.');
    }
  }

  if (
    $vocabulary_name === 'eiw_roles' &&
    !empty($form['terms']) &&
    is_array($form['terms'])
  ) {
    // Remove form help (unusable for non-nested terms).
    unset($form['help']);

    foreach (array_keys($form['terms']) as $row_key) {
      if (strpos($row_key, 'tid:') === 0 && isset($form['terms'][$row_key]['term'])) {
        // Load the term for its label.
        $parts = explode(':', $row_key);
        $tid = $parts[1];
        $term = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($tid);
        if ($term) {
          $url = \Drupal\Core\Url::fromUri('internal:/audit-wills/all/all/' . $tid);
          $link = [
            '#type' => 'link',
            '#title' => $term->label(),
            '#url' => $url,
            '#attributes' => ['class' => ['custom-admin-role-link']],
          ];
          $form['terms'][$row_key]['term'] = $link;
        }
      }
    }
  }
}

/**
 * Implements hook_preprocess_node().
 */
function eiw_core_preprocess_node(array &$variables) {
  $node = $variables['node'];
  
  // Only alter nodes of type 'eiw_will'.
  if ($node && $node->bundle() === 'eiw_will') {
    // Helper function to alter field display if boolean is TRUE.
    $alter_year_only = function ($field_name, $year_only_field) use (&$variables, $node) {
      if (
        $node->hasField($year_only_field) &&
        !$node->get($year_only_field)->isEmpty() &&
        $node->get($year_only_field)->value &&
        $node->hasField($field_name) &&
        !$node->get($field_name)->isEmpty() &&
        isset($variables['content'][$field_name]['#items'][0]->value)
      ) {
        $date_value = $node->get($field_name)->value;
        $year = substr($date_value, 0, 4);

        // Update only the rendered value, preserving the rest of the render array.
        foreach ($variables['content'][$field_name] as $delta => &$item) {
          if (is_array($item) && isset($item['#markup'])) {
            $item['#markup'] = $year;
          }
        }
        // Also update the raw item for other formatters.
        if (isset($variables['content'][$field_name]['#items'][0]->value)) {
          $variables['content'][$field_name]['#items'][0]->value = $year;
        }
      }
    };

    // Apply for both fields.
    $alter_year_only('field_date_of_probate', 'field_year_only_probate');
    $alter_year_only('field_date_of_will', 'field_year_only_will');

    // Override Courts field link on will display and redirect to audit-wills view.
    if (!empty($variables['content']['field_court']) and isset($variables['content']['field_court']['#items'])) {
      // Loop through all referenced entities (should be just one).
      foreach ($variables['content']['field_court']['#items'] as $delta => $item) {
        // Load the referenced node.
        $tid = $item->target_id;
        $term = \Drupal::entityTypeManager()
          ->getStorage('taxonomy_term')
          ->load($tid);

        if ($term && $term->bundle() == 'eiw_courts') {
          // Build your custom link. Example: change to a custom path or alter the link text.
          $url = Url::fromUri('internal:/audit-wills/all/all/all/' . $tid);
          $link = Link::fromTextAndUrl($term->getName(), $url)->toRenderable();
          // Optionally, add custom classes or attributes.
          $link['#attributes']['class'][] = 'my-custom-court-link';
          // Override the rendered field output.
          $variables['content']['field_court'][$delta] = $link;
        }
      }
    }
  }
}

/**
 * Implements hook_preprocess_paragraph().
 */
function eiw_core_preprocess_paragraph(array &$variables) {
  /**
   * Override voyage, ship, and role links to audit-wills when paragraph is displayed.
   * Only target the 'eiw_will_voyage' paragraph type.
   */ 
  if ($variables['paragraph']->bundle() === 'eiw_will_voyage') {
    // Handle field_voyage.
    if (!empty($variables['content']['field_voyage']) and isset($variables['content']['field_voyage']['#items'])) {
      // Loop through all referenced entities (should be just one).
      foreach ($variables['content']['field_voyage']['#items'] as $delta => $item) {
        // Load the referenced node.
        $nid = $item->target_id;
        $node = \Drupal::entityTypeManager()
          ->getStorage('node')
          ->load($nid);

        if ($node && $node->bundle() == 'eiw_voyage') {
          // Build your custom link. Example: change to a custom path or alter the link text.
          $url = Url::fromUri('internal:/audit-wills/' . $nid);
          $link = Link::fromTextAndUrl($node->label(), $url)->toRenderable();
          // Optionally, add custom classes or attributes.
          $link['#attributes']['class'][] = 'my-custom-voyage-link';
          // Override the rendered field output.
          $variables['content']['field_voyage'][$delta] = $link;
        }
      }
    }
    // Handle field_ship.
    if (!empty($variables['content']['field_ship']) and isset($variables['content']['field_ship']['#items'])) {
      // Loop through all referenced entities (should be just one).
      foreach ($variables['content']['field_ship']['#items'] as $delta => $item) {
        // Load the referenced node.
        $nid = $item->target_id;
        $node = \Drupal::entityTypeManager()
          ->getStorage('node')
          ->load($nid);

        if ($node && $node->bundle() == 'eiw_ship') {
          // Build your custom link. Example: change to a custom path or alter the link text.
          $url = Url::fromUri('internal:/audit-wills/all/' . $nid);
          $link = Link::fromTextAndUrl($node->label(), $url)->toRenderable();
          // Optionally, add custom classes or attributes.
          $link['#attributes']['class'][] = 'my-custom-ship-link';
          // Override the rendered field output.
          $variables['content']['field_ship'][$delta] = $link;
        }
      }
    }
    // Handle field_role for taxonomy term references.
    if (!empty($variables['content']['field_role']) and isset($variables['content']['field_role']['#items'])) {
      foreach ($variables['content']['field_role']['#items'] as $delta => $item) {
        $term = \Drupal::entityTypeManager()
          ->getStorage('taxonomy_term')
          ->load($item->target_id);

        if ($term && $term->bundle() === 'eiw_roles') {
          // Custom link to /wills faceted by role.
          $url = Url::fromUri('internal:/wills/?f%5B0%5D=will_role_names_facet%3A' . urlencode($term->getName()));
          $link = Link::fromTextAndUrl($term->label(), $url)->toRenderable();
          $link['#attributes']['class'][] = 'custom-role-link';
          $variables['content']['field_role'][$delta] = $link;
        }
      }
    }
  }
}

/**
 * Implements hook_preprocess_field().
 */
function eiw_core_preprocess_field(array &$variables) {
  if (
    !empty($variables['element']['#entity_type']) &&
    $variables['element']['#entity_type'] === 'node' &&
    !empty($variables['element']['#field_name']) &&
    $variables['element']['#field_name'] === 'title' &&
    !empty($variables['element']['#view_mode']) &&
    $variables['element']['#view_mode'] === 'full'
  ) {
    $bundle = $variables['element']['#bundle'] ?? '';
    foreach ($variables['items'] as &$item) {
      if (
        isset($item['content']['#context']['value']) &&
        is_string($item['content']['#context']['value'])
      ) {
        $original = $item['content']['#context']['value'];
        if ($bundle === 'eiw_voyage') {
          $item['content']['#context']['value'] = t('Voyage: @title', ['@title' => $original]);
        }
        elseif ($bundle === 'eiw_ship') {
          $item['content']['#context']['value'] = t('Ship: @title', ['@title' => $original]);
        }
      }
    }
  }
}

