<?php

/**
 * Implements hook_ENTITY_TYPE_presave().
 */
function eiw_core_node_presave($entity) {
  // Check if the entity is a node of type 'eiw_will'.
  if ($entity->bundle() === 'eiw_will') {
    // Set title to name values (single value fields).
    $first_name = trim($entity->get('field_first_name')->value) ?? 'N/A';
    $last_name = trim($entity->get('field_last_name')->value) ?? 'N/A';
    $entity->setTitle("$last_name, $first_name");
  }
}