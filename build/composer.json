{
  "authors": [
    {
      "name": "UNB Libraries libsupport@unb.ca",
      "role": "Creator"
    }
  ],
  "autoload": {
    "classmap": [
      "scripts/composer/ScriptHandler.php"
    ]
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "cweagans/composer-patches": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "drupal/core-composer-scaffold": true,
      "php-http/discovery": true,
      "phpstan/extension-installer": true,
      "tbachert/spi": true
    },
    "discard-changes": true,
    "preferred-install": {
      "*": "dist"
    },
    "sort-packages": true
  },
  "conflict": {
    "drupal/drupal": "*"
  },
  "description": "Drupal 8 component of eastindiawills.lib.unb.ca",
  "extra": {
    "drupal-scaffold": {
      "locations": {
        "web-root": "./"
      }
    },
    "enable-patching": true,
    "installer-paths": {
      "core": [
        "type:drupal-core"
      ],
      "libraries/{$name}": [
        "type:drupal-library"
      ],
      "modules/contrib/{$name}": [
        "type:drupal-module"
      ],
      "profiles/contrib/{$name}": [
        "type:drupal-profile"
      ],
      "themes/contrib/{$name}": [
        "type:drupal-theme"
      ],
      "Commands/contrib/{$name}": [
        "type:drupal-drush"
      ],
      "modules/custom/{$name}": [
        "type:drupal-custom-module"
      ],
      "profiles/custom/{$name}": [
        "type:drupal-custom-profile"
      ],
      "themes/custom/{$name}": [
        "type:drupal-custom-theme"
      ]
    }
  },
  "license": "MIT",
  "minimum-stability": "dev",
  "name": "unb-libraries/eastindiawills.lib.unb.ca",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "composer",
      "url": "https://packages.drupal.org/8",
      "exclude": ["drupal/fontawesome_iconpicker"]
    },
    {
      "type": "package",
      "package": {
        "name": "appolodev/vanilla-icon-picker",
        "version": "v1.1.3",
        "type": "drupal-library",
        "dist": {
          "url": "https://github.com/AppoloDev/vanilla-icon-picker/archive/refs/tags/v1.1.3.zip",
          "type": "zip"
        }
      }
    },
    {
      "package": {
        "name": "fontawesome/fontawesome",
        "version": "6.7.2",
        "type": "drupal-library",
        "extra": {
          "installer-name": "fontawesome"
        },
        "dist": {
          "url": "https://use.fontawesome.com/releases/v6.7.2/fontawesome-free-6.7.2-web.zip",
          "type": "zip"
        }
      },
      "type": "package"
    },
    {
      "package": {
        "name": "jacklmoore/colorbox",
        "version": "dev-master",
        "type": "drupal-library",
        "extra": {
          "installer-name": "colorbox"
        },
        "dist": {
          "url": "https://github.com/jackmoore/colorbox/archive/master.zip",
          "type": "zip"
        }
      },
      "type": "package"
    },
    {
      "type": "package",
      "package": {
        "name": "simeydotme/jquery-ui-slider-pips",
        "version": "2.0.0",
        "type": "drupal-library",
        "dist": {
          "url": "https://github.com/simeydotme/jQuery-ui-Slider-Pips/archive/refs/tags/2.0.0.zip",
          "type": "zip"
        }
      }
    },
    {
      "type": "vcs",
      "url": "https://github.com/unb-libraries/fontawesome_iconpicker"
    }
  ],
  "require": {
    "drupal/core-composer-scaffold": "^10",
    "drupal/core-recommended": "^10",
    "drupal/core": "^10",
    "drupal/admin_toolbar": "^3",
    "drupal/better_exposed_filters": "^7",
    "drupal/bootstrap5": "^4",
    "drupal/ckeditor5_plugin_pack": "^1",
    "drupal/colorbox": "^2",
    "drupal/editor_file": "^1",
    "drupal/entity_browser": "^2",
    "drupal/facets": "^3",
    "drupal/file_management": "^2",
    "drupal/fontawesome": "^3",
    "drupal/google_analytics": "^4",
    "drupal/health_check": "^3",
    "drupal/honeypot": "^2",
    "drupal/jquery_ui": "^1",
    "drupal/jquery_ui_touch_punch": "^1",
    "drupal/jquery_ui_slider": "^2",
    "drupal/linkit": "^7.0",
    "drupal/media_entity_browser": "^2",
    "drupal/noreqnewpass": "^1",
    "drupal/override_node_options": "^2",
    "drupal/paragraphs": "^1",
    "drupal/pathauto": "^1",
    "drupal/redis": "^1",
    "drupal/require_login": "^3",
    "drupal/samlauth": "^3",
    "drupal/search_api": "^1",
    "drupal/search_api_autocomplete": "^1",
    "drupal/search_api_solr": "^4",
    "drupal/simple_sitemap": "^4",
    "drupal/tagify": "^1",
    "drupal/token": "^1",
    "drupal/twig_tweak": "^3",
    "drupal/view_unpublished": "^1",
    "drupal/unpublished_node_permissions": "^1",
    "fontawesome/fontawesome": "^6",
    "jacklmoore/colorbox": "dev-master",
    "simeydotme/jquery-ui-slider-pips": "^2",
    "unb-libraries/saml_features": "dev-10.x-1.x",
    "unb-libraries/composer-drupal-scaffold": "^10"
  },
  "require-dev": {
    "unb-libraries/drupal-development-libraries": "^10"
  },
  "type": "project"
}
