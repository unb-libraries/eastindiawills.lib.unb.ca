# Local-only development Drupal environment settings. These are not applied
# to production.

DEPLOY_ENV=local

LOCAL_HOSTNAME=local-eastindiawills.lib.unb.ca
LOCAL_PORT=3120
LOCAL_USER_GROUP=1000

DRUPAL_ADMIN_ACCOUNT_NAME=admin
DRUPAL_ADMIN_ACCOUNT_PASS=dockeradminpass
DRUPAL_TESTING_TOOLS=TRUE

DRUPAL_DB_HOSTNAME=drupal-mysql-lib-unb-ca
DRUPAL_DB_NAME=drupal
DRUPAL_DB_PASSWORD=drupal
DRUPAL_DB_PORT=3306
DRUPAL_DB_USER=drupal